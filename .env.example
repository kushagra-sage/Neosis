# ─────────────────────────────────────────────────────────────────────────────
# Noesis — environment configuration
# Copy to `.env` and fill in secrets. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Noesis
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false                 # true in production
API_V1_PREFIX=/api/v1

# ── Security / CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
JWT_SECRET_KEY=change-me-in-production    # python -c "import secrets;print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=noesis
POSTGRES_USER=noesis
POSTGRES_PASSWORD=noesis
# DATABASE_URL_OVERRIDE=postgresql+asyncpg://user:pass@host:5432/db   # e.g. Neon

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false
QDRANT_API_KEY=
QDRANT_COLLECTION=noesis_papers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
VECTOR_DISTANCE=Cosine

# ── MinIO (object store) ──────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=noesis
MINIO_SECRET_KEY=noesis-secret
MINIO_BUCKET=noesis-papers
MINIO_SECURE=false

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Scholarly retrieval (Phase 2) ─────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
RETRIEVER_TOP_K=10
RETRIEVER_RRF_K=60

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth redirect targets (shared by GitHub + Google)
OAUTH_FRONTEND_URL=http://localhost:3000
OAUTH_BACKEND_URL=http://localhost:8000

# ── Password reset / email (optional) ─────────────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@noesis.app

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated usernames or emails granted admin dashboard access.
ADMIN_EMAILS=
