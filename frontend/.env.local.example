# Public base URL of the Noesis backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# OAuth (optional). GitHub initiator defaults to the backend's documented path.
# NEXT_PUBLIC_GITHUB_OAUTH_URL=http://localhost:8000/api/v1/auth/github/login
# Leave Google empty until the backend route exists — the button stays disabled.
# NEXT_PUBLIC_GOOGLE_OAUTH_URL=

# OAuth begin routes (default to the backend's documented paths)
# NEXT_PUBLIC_GITHUB_OAUTH_URL=http://localhost:8000/api/v1/auth/oauth/github
# NEXT_PUBLIC_GOOGLE_OAUTH_URL=http://localhost:8000/api/v1/auth/oauth/google
